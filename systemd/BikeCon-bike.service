# /etc/systemd/system/BikeCon-bike.service
[Unit]
Description=BikeCon Bike Service (Driver + Pub/Sub)
Requires=BikeCon-mixer.service
After=BikeCon-mixer.service bluetooth.target

[Service]
Type=simple
User=root
Group=bikecon
WorkingDirectory=/opt/BikeCon
ExecStart=/opt/BikeCon/venv/bin/python3 bike_service.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1
KillSignal=SIGTERM
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
